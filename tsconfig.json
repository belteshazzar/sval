{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "es2021"],
    "declaration": true,
    "noImplicitAny": false,
    "removeComments": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "declarationDir": "types",
    "emitDeclarationOnly": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}